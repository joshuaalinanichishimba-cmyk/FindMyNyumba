# ─────────────────────────────────────────────────────────────────────────
# FindMyNyumba — environment template
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.
#
# IMPORTANT: the SECRET_KEY and admin seed password that were previously in the
# committed .env should be treated as compromised — rotate them now:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────────────

# --- Security (REQUIRED) ---
# 64-char hex string. App refuses to start if shorter than 32 chars.
SECRET_KEY=replace_me_with_a_freshly_generated_64_char_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# --- Database (REQUIRED) ---
# Supabase/Postgres connection string.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# --- Deployment flags ---
PRODUCTION=false
FRONTEND_URL=https://find-my-nyumba-original.vercel.app
BACKEND_URL=http://127.0.0.1:8000

# --- CORS (comma-separated, no spaces needed) ---
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://find-my-nyumba-original.vercel.app,https://nyumba-web.vercel.app

# --- Admin bootstrap (used only on first login to seed the master account) ---
ADMIN_SEED_EMAIL=admin@findmynyumba.com
ADMIN_SEED_PASSWORD=replace_me_with_a_strong_password

# --- Email (Resend) ---
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
MAIL_FROM_NAME=FindMyNyumba

# --- Google Sign-In ---
GOOGLE_CLIENT_ID=

# --- Cloudinary (media storage) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Sentry error monitoring (NEW; optional) ---
# Leave blank to disable. Set the DSN from your Sentry project to turn it on.
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.0
