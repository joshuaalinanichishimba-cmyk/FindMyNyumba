# ============================================================
# FindMyNyumba — Environment Variables Template
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/findmynyumba
# SQLite (local development only):
DATABASE_URL=sqlite:///./findmynyumba.db

# ── Security ──────────────────────────────────────────────────
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# MUST be at least 32 characters. App will refuse to start without it.
SECRET_KEY=REPLACE_THIS_WITH_A_REAL_SECRET_KEY_AT_LEAST_32_CHARS

# ── URLs ──────────────────────────────────────────────────────
# Update these when deploying to production
FRONTEND_URL=http://localhost:5500
BACKEND_URL=http://127.0.0.1:8000

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# For production, replace with your actual domain.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ── Admin Seed ───────────────────────────────────────────────
# These are used ONCE on first login to auto-create the admin account.
# Change the password immediately after first login.
# Set ADMIN_SEED_PASSWORD to enable the seed; leave blank to disable.
ADMIN_SEED_EMAIL=admin@findmynyumba.com
ADMIN_SEED_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520
